* {
    margin: 0;
    padding: 0;
}

body {
    font-family: 'Roboto', sans-serif;
    display: flex;
    flex-direction: column; /* Mobile-First */
    justify-content: center;
    align-items: center;
    background-color: #f4f4f4;
    text-align: center;
}

header {
    width: 70%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.foto img {
    width: 15vw;
    border-radius: 100%;
    padding: 2vh;
}

.descricao-pessoal {
    margin-top: 2vh;
}
